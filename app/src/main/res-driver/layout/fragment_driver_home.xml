<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/driver_bg"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingBottom="16dp"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="118dp"
            android:background="@drawable/bg_driver_header"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="18dp"
            android:paddingBottom="22dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_home_avatar"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_driver_avatar_placeholder"
                app:civ_border_color="#80FFFFFF"
                app:civ_border_width="2dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chế độ tài xế"
                    android:textColor="#D6E2FF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_home_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tài xế"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- NỘI DUNG -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingHorizontal="14dp">

            <!-- THẺ CÔNG TẮC NHẬN CHUYẾN -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-26dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_receive"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="#FFFFFF"
                        app:trackTint="@color/driver_green" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_receive_state"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đang nhận chuyến"
                            android:textColor="@color/driver_text"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bạn đang ở chế độ nhận chuyến gần nhất"
                            android:textColor="@color/driver_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_toggle_receive"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="Tắt nhận chuyến"
                        android:textColor="@color/driver_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/driver_surface_blue"
                        app:cornerRadius="20dp"
                        app:elevation="0dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BẢN ĐỒ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_map_stub" />
            </androidx.cardview.widget.CardView>

            <!-- CHUYẾN GẦN NHẤT -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:paddingHorizontal="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="Chuyến gần nhất"
                    android:textColor="@color/driver_text"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Tự động nhận: Tắt"
                    android:textColor="@color/driver_text_secondary"
                    android:textSize="12sp" />
            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_nearest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:id="@+id/box_n_left"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_n_cartype"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_pill_round"
                                android:backgroundTint="@color/driver_surface_blue"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="3dp"
                                android:text="4 chỗ"
                                android:textColor="@color/driver_primary"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_star"
                                    app:tint="@color/driver_orange" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="3dp"
                                    android:text="4.8"
                                    android:textColor="@color/driver_text"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:text="Khách hàng"
                                    android:textColor="@color/driver_text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Giá dự kiến"
                                android:textColor="@color/driver_text_secondary"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tv_n_price"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="145.000đ"
                                android:textColor="@color/driver_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="end"
                                android:background="@drawable/bg_pill_round"
                                android:backgroundTint="#EEF1F5"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:text="💵 Tiền mặt"
                                android:textColor="@color/driver_text_secondary"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_dot"
                            android:backgroundTint="@color/driver_green" />

                        <TextView
                            android:id="@+id/tv_n_pickup"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:text="Nguyễn Huệ, Quận 1, TPHCM"
                            android:textColor="@color/driver_text"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_dot"
                            android:backgroundTint="@color/driver_red" />

                        <TextView
                            android:id="@+id/tv_n_dest"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:text="Khu Công nghệ cao, Thủ Đức"
                            android:textColor="@color/driver_text"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_clock"
                            app:tint="@color/driver_text_secondary" />

                        <TextView
                            android:id="@+id/tv_n_meta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:text="6.2 km · 18 phút"
                            android:textColor="@color/driver_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_n_skip"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="Bỏ qua (15)"
                            android:textColor="@color/driver_text_secondary"
                            app:cornerRadius="12dp"
                            app:strokeColor="@color/driver_divider" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_n_accept"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1.4"
                            android:backgroundTint="@color/driver_primary"
                            android:text="Nhận chuyến"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_no_nearest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_round_16"
                android:gravity="center"
                android:paddingVertical="26dp"
                android:text="Chưa có chuyến nào đang chờ"
                android:textColor="@color/driver_text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- TỔNG QUAN HÔM NAY -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="20dp"
                android:text="Tổng quan hôm nay"
                android:textColor="@color/driver_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp">

                    <include layout="@layout/item_driver_overview_stat" android:id="@+id/stat_revenue"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                    <include layout="@layout/item_driver_overview_stat" android:id="@+id/stat_trips"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                    <include layout="@layout/item_driver_overview_stat" android:id="@+id/stat_rating"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                    <include layout="@layout/item_driver_overview_stat" android:id="@+id/stat_online"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- NHẮC AN TOÀN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_round_16"
                android:backgroundTint="@color/driver_surface_blue"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_shield"
                    app:tint="@color/driver_primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giữ an toàn cho bạn và hành khách"
                        android:textColor="@color/driver_text"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Luôn tuân thủ luật giao thông và đỗ xe đúng nơi quy định."
                        android:textColor="@color/driver_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
