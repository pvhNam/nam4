<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/driver_bg"
    android:orientation="vertical">

    <include
        android:id="@+id/driver_header"
        layout="@layout/include_driver_greeting_header" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_period"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:tabGravity="fill"
        app:tabIndicatorColor="@color/driver_primary"
        app:tabIndicatorFullWidth="false"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed"
        app:tabSelectedTextColor="@color/driver_primary"
        app:tabTextColor="@color/driver_text_secondary" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp">

            <!-- Thẻ tổng quan kỳ (gradient xanh) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_blue_gradient_card"
                android:orientation="horizontal"
                android:paddingVertical="20dp">

                <LinearLayout style="@style/EarningStatCol">

                    <TextView
                        android:id="@+id/tv_e_revenue"
                        style="@style/EarningStatValue"
                        android:text="0đ" />

                    <TextView style="@style/EarningStatLabel" android:text="Doanh thu" />
                </LinearLayout>

                <View style="@style/EarningDivider" />

                <LinearLayout style="@style/EarningStatCol">

                    <TextView
                        android:id="@+id/tv_e_trips"
                        style="@style/EarningStatValue"
                        android:text="0" />

                    <TextView style="@style/EarningStatLabel" android:text="Số chuyến" />
                </LinearLayout>

                <View style="@style/EarningDivider" />

                <LinearLayout style="@style/EarningStatCol">

                    <TextView
                        style="@style/EarningStatValue"
                        android:text="8h 30m" />

                    <TextView style="@style/EarningStatLabel" android:text="Online" />
                </LinearLayout>
            </LinearLayout>

            <!-- Ví tài xế -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_circle_soft"
                            android:backgroundTint="@color/driver_green_bg">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_dnav_wallet"
                                app:tint="@color/driver_green" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ví tài xế"
                                android:textColor="@color/driver_text"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Số dư hiện tại"
                                android:textColor="@color/driver_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_e_balance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0đ"
                            android:textColor="@color/driver_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_withdraw"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:backgroundTint="@color/driver_primary"
                            android:text="Rút tiền"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:cornerRadius="12dp"
                            app:icon="@drawable/ic_withdraw"
                            app:iconGravity="textStart"
                            app:iconSize="18dp"
                            app:iconTint="#FFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_txn_history"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:text="Lịch sử"
                            android:textColor="@color/driver_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:cornerRadius="12dp"
                            app:icon="@drawable/ic_history"
                            app:iconGravity="textStart"
                            app:iconSize="18dp"
                            app:iconTint="@color/driver_primary"
                            app:strokeColor="@color/driver_primary" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Thu nhập theo ngày -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="Thu nhập theo ngày"
                            android:textColor="@color/driver_text"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Xem chi tiết"
                            android:textColor="@color/driver_primary"
                            android:textSize="12sp" />
                    </RelativeLayout>

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/chart_income"
                        android:layout_width="match_parent"
                        android:layout_height="190dp"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Thưởng / Ưu đãi -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:paddingHorizontal="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="Thưởng / Ưu đãi"
                    android:textColor="@color/driver_text"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Xem thêm"
                    android:textColor="@color/driver_primary"
                    android:textSize="12sp" />
            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_circle_soft"
                            android:backgroundTint="@color/driver_orange_bg">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_star"
                                app:tint="@color/driver_orange" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Thưởng đạt mốc 10 chuyến"
                            android:textColor="@color/driver_text"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+50.000đ"
                            android:textColor="@color/driver_green"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progress_reward"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="14dp"
                        android:max="10"
                        android:progress="7"
                        android:progressTint="@color/driver_primary"
                        android:progressBackgroundTint="@color/driver_divider" />

                    <TextView
                        android:id="@+id/tv_reward_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="6dp"
                        android:text="7 / 10 chuyến"
                        android:textColor="@color/driver_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
