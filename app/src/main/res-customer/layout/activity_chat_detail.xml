<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_liquid_glass"
    android:fitsSystemWindows="true">

    <!-- ══════════════════════════════════════════════════════════════
         HEADER  (tên đối phương + icon tìm kiếm + menu)
    ══════════════════════════════════════════════════════════════ -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/blur_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@color/lg_glass_fill_strong"
        android:elevation="4dp">

    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hàng chính: back | tên | search-icon + menu -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                app:tint="@color/lg_text" />

            <TextView
                android:id="@+id/tv_partner_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Người dùng"
                android:textColor="@color/lg_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_search_toggle"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/lg_text" />

                <ImageButton
                    android:id="@+id/btn_menu_more"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_more"
                    app:tint="@color/lg_text" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Thanh tìm kiếm tin nhắn trong đoạn chat (ẩn mặc định) -->
        <LinearLayout
            android:id="@+id/layout_search_bar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/lg_glass_fill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/et_search_messages"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/bg_glass_input"
                android:hint="Tìm tên hoặc nội dung tin nhắn..."
                android:textColorHint="@color/lg_text_secondary"
                android:textColor="@color/lg_text"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true" />

            <ImageButton
                android:id="@+id/btn_search_close"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/lg_text" />
        </LinearLayout>

        <!-- Thanh điều hướng kết quả tìm kiếm (ẩn mặc định) -->
        <LinearLayout
            android:id="@+id/layout_search_nav"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@color/lg_glass_fill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_search_result_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 kết quả"
                android:textColor="@color/lg_text_secondary"
                android:textSize="13sp" />

            <ImageButton
                android:id="@+id/btn_search_prev"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/arrow_up_float"
                app:tint="@color/lg_text" />

            <ImageButton
                android:id="@+id/btn_search_next"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/arrow_down_float"
                app:tint="@color/lg_text" />
        </LinearLayout>

        <!-- Car info widget -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/lg_glass_fill_strong"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/iv_car"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_buy_car" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/iv_car"
                    android:layout_toStartOf="@id/btn_view_post"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_car_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tên xe"
                        android:textColor="@color/color_on_surface"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tv_car_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giá xe"
                        android:textColor="#E53935"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_view_post"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="Xem"
                    android:textSize="11sp" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
    </eightbitlab.com.blurview.BlurView>

    <!-- ══════════════════════════════════════════════════════════════
         BANNER BỊ CHẶN — đặt DƯỚI header, TRÊN rv_messages
         rv_messages sẽ layout_below banner này
    ══════════════════════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tv_blocked_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/blur_header"
        android:background="#FFCDD2"
        android:gravity="center"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="🚫 Bạn đã bị chặn bởi người này. Không thể gửi tin nhắn."
        android:textColor="#C62828"
        android:textSize="13sp"
        android:textStyle="bold"
        android:elevation="3dp"
        android:visibility="gone" />

    <!-- ══════════════════════════════════════════════════════════════
         MEDIA PICKER PANEL  (từ dưới lên)
    ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layout_media_picker"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_alignParentBottom="true"
        android:background="@color/lg_glass_fill_strong"
        android:elevation="12dp"
        android:orientation="vertical"
        android:visibility="gone">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#F5F5F5"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <LinearLayout
                android:id="@+id/btn_picker_image"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentStart="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/iv_tab_image"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/send_pic" />

                <View
                    android:id="@+id/indicator_image"
                    android:layout_width="3dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:background="@color/lg_accent"
                    android:visibility="visible" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_picker_video"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_toEndOf="@id/btn_picker_image"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/iv_tab_video"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/video_content"
                    android:alpha="0.45" />

                <View
                    android:id="@+id/indicator_video"
                    android:layout_width="3dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:background="@color/lg_accent"
                    android:visibility="invisible" />
            </LinearLayout>

            <ImageView
                android:id="@+id/tv_picker_close"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_cross_bl"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp" />
        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_media_picker"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false" />

        <Button
            android:id="@+id/btn_picker_send"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="@color/lg_accent"
            android:text="Gửi"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════
         INPUT AREA  (phía trên media picker)
    ══════════════════════════════════════════════════════════════ -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/blur_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_above="@id/layout_media_picker"
        android:background="@color/lg_glass_fill_soft"
        android:elevation="12dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_input" android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingEnd="4dp">

            <ImageButton
                android:id="@+id/btn_add_image"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_add_pictures" />

            <EditText
                android:id="@+id/et_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Gõ tin nhắn..."
                android:textColorHint="#9CA3AF"
                android:textColor="#1A1A2E"
                android:maxLines="4"
                android:paddingVertical="12dp"
                android:paddingHorizontal="4dp"
                android:textSize="15sp" />

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_accent"
                android:layout_margin="4dp">

                <ImageButton
                    android:id="@+id/btn_send"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:enabled="false"
                    android:src="@drawable/ic_send"
                    android:padding="10dp"
                    android:scaleType="fitCenter"
                    app:tint="#FFFFFF" />
            </FrameLayout>
        </LinearLayout>
    </eightbitlab.com.blurview.BlurView>

    <!-- ══════════════════════════════════════════════════════════════
         DANH SÁCH TIN NHẮN
         layout_below="@id/tv_blocked_banner" → banner luôn hiện trước
    ══════════════════════════════════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:layout_alignParentBottom="true"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingTop="96dp"
        android:paddingBottom="84dp" />

    <!-- ══════════════════════════════════════════════════════════════
         LOADING OVERLAY
    ══════════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/layout_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_info_card"
            android:padding="20dp">

            <ProgressBar
                android:layout_width="40dp"
                android:layout_height="40dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Đang tải lên..."
                android:textColor="@color/color_on_surface"
                android:textSize="13sp" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/layout_media_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:visibility="gone"
        android:elevation="10dp">

        <com.github.chrisbanes.photoview.PhotoView
            android:id="@+id/photo_view_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <VideoView
                android:id="@+id/video_view_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progress_video_overlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

        <ImageView
            android:id="@+id/btn_close_overlay"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:background="@drawable/bg_circle_blue"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@android:color/white"
            android:clickable="true"
            android:focusable="true" />
    </FrameLayout>

</RelativeLayout>