<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingBottom="96dp"
    android:scrollbars="none">

    <LinearLayout
        android:id="@+id/layout_post_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="18dp"
        android:paddingBottom="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đăng tin xe"
            android:textColor="@color/color_on_background"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Nhập thông tin chính để gửi admin duyệt."
            android:textColor="@color/color_on_surface_secondary"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Ảnh xe"
            android:textColor="@color/color_on_surface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/layout_upload_media"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_post_upload">

            <ImageView
                android:id="@+id/iv_car_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layout_upload_prompt"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thêm ảnh xe"
                    android:textColor="@color/color_on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Có thể chọn nhiều ảnh cùng lúc"
                    android:textColor="@color/color_on_surface_secondary"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btn_pick_image"
                    android:layout_width="136dp"
                    android:layout_height="42dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#2F7BD7"
                    android:text="Chọn ảnh"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <HorizontalScrollView
            android:id="@+id/scroll_image_thumbs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/layout_image_thumbs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_image_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/color_on_surface_secondary"
                android:textSize="12sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_remove_image"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:backgroundTint="#E53935"
                android:text="Xóa tất cả"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Thông tin xe"
            android:textColor="@color/color_on_background"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Tên xe *"
            android:textColor="@color/color_on_surface"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_car_name"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_search"
            android:hint="Toyota Vios 2020"
            android:inputType="textCapWords"
            android:padding="12dp"
            android:textColor="@color/color_on_surface"
            android:textColorHint="@color/color_on_surface_tertiary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hãng xe *"
                    android:textColor="@color/color_on_surface"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinner_brand"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_search" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loại tin *"
                    android:textColor="@color/color_on_surface"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinner_type"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_search" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Mức giá *"
            android:textColor="@color/color_on_surface"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_car_price"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_search"
            android:hint="450000000"
            android:inputType="number"
            android:padding="12dp"
            android:textColor="@color/color_on_surface"
            android:textColorHint="@color/color_on_surface_tertiary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Năm sản xuất"
                    android:textColor="@color/color_on_surface"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_car_year"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_search"
                    android:hint="2020"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textColor="@color/color_on_surface"
                    android:textColorHint="@color/color_on_surface_tertiary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số km"
                    android:textColor="@color/color_on_surface"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_car_km"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_search"
                    android:hint="50000"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textColor="@color/color_on_surface"
                    android:textColorHint="@color/color_on_surface_tertiary" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Khu vực"
            android:textColor="@color/color_on_surface"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_car_location"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_search"
            android:hint="Quận 1, TP.HCM"
            android:inputType="textCapWords"
            android:padding="12dp"
            android:textColor="@color/color_on_surface"
            android:textColorHint="@color/color_on_surface_tertiary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Mô tả thêm"
            android:textColor="@color/color_on_surface"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_car_info"
            android:layout_width="match_parent"
            android:layout_height="112dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_search"
            android:gravity="top|start"
            android:hint="Tình trạng xe, giấy tờ, lịch sử bảo dưỡng..."
            android:inputType="textMultiLine|textCapSentences"
            android:padding="12dp"
            android:textColor="@color/color_on_surface"
            android:textColorHint="@color/color_on_surface_tertiary" />

        <Button
            android:id="@+id/btn_submit_post"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_search_button"
            android:text="Gửi yêu cầu đăng tin"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>