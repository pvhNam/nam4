<?xml version="1.0" encoding="utf-8"?>
<!-- Nút nguy hiểm (đăng xuất/từ chối) Liquid Glass: gradient đỏ bóng -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#FF7B7B"
        android:endColor="#E5484D" />
    <corners android:radius="26dp" />
    <stroke
        android:width="1dp"
        android:color="@color/lg_glass_stroke" />
</shape>
