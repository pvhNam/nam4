<?xml version="1.0" encoding="utf-8"?>
<!-- Khung nhập Liquid Glass: kính trong gradient chéo, bo mềm + viền sáng -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <corners android:radius="16dp" />
    <gradient
        android:type="linear"
        android:angle="315"
        android:startColor="@color/lg_glass_fill_strong"
        android:endColor="@color/lg_glass_fill" />
    <stroke
        android:width="1dp"
        android:color="@color/lg_glass_stroke_dim" />
</shape>
