<?xml version="1.0" encoding="utf-8"?>
<!-- Header lọc (Liquid Glass): gradient teal. Bo góc TRÊN, đáy PHẲNG để
     nối liền xuống panel nội dung bên dưới (cùng cột bo tròn). -->
