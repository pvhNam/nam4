<?xml version="1.0" encoding="utf-8"?>
<!-- Nút tròn kính mờ nổi riêng — ánh sáng bắt từ trên-trái cho cảm giác khối -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="linear"
        android:angle="315"
        android:startColor="@color/lg_glass_fill_strong"
        android:endColor="@color/lg_glass_fill_soft" />
    <stroke
        android:width="1dp"
        android:color="@color/lg_glass_stroke" />
</shape>
