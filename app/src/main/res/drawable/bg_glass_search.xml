<?xml version="1.0" encoding="utf-8"?>
<!-- Ô tìm kiếm kính mờ bo tròn (giống thanh "Bạn muốn đi đâu?") — ánh sáng chéo -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="28dp" />
    <gradient
        android:type="linear"
        android:angle="315"
        android:startColor="@color/lg_glass_fill_strong"
        android:centerColor="@color/lg_glass_fill"
        android:endColor="@color/lg_glass_fill_soft" />
    <stroke
        android:width="1dp"
        android:color="@color/lg_glass_stroke" />
</shape>
