<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivCarSale"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/color_image_placeholder"
            android:scaleType="centerCrop"
            android:src="@color/color_image_placeholder" />

        <TextView
            android:id="@+id/tvCarSaleName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="Toyota Vios 2020"
            android:textColor="@color/color_on_background"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCarSalePrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="450.000.000 VNĐ"
            android:textColor="@android:color/holo_red_dark"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvCarSaleInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="TP.HCM • 2020 • Tự động"
            android:textColor="@color/color_on_surface_secondary"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnViewDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_margin="8dp"
            android:backgroundTint="#1976D2"
            android:text="XEM CHI TIẾT"
            android:textColor="@android:color/white"
            android:textSize="12sp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>