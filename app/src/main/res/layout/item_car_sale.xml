<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/lg_glass_fill_strong"
    app:strokeColor="@color/lg_glass_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="130dp">

            <ImageView
                android:id="@+id/ivCarSale"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/color_image_placeholder"
                android:scaleType="centerCrop"
                android:src="@color/color_image_placeholder" />

            <ImageView
                android:id="@+id/iv_favorite_sale"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_scrim"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Yêu thích"
                android:padding="7dp"
                android:src="@drawable/ic_heart_outline" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/tvCarSaleName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Toyota Vios 2020"
                android:textColor="@color/color_on_background"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCarSalePrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="450.000.000 VNĐ"
                android:textColor="#D32F2F"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCarSaleInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="TP.HCM • 2020 • Tự động"
                android:textColor="@color/color_on_surface_secondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnViewDetails"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/lg_accent"
                app:strokeColor="@color/lg_glass_stroke"
                app:strokeWidth="1dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text="XEM CHI TIẾT"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
