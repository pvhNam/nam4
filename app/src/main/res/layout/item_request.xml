<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/color_surface"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- LOẠI YÊU CẦU + TRẠNG THÁI + THỜI GIAN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvRequestType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_type"
                android:paddingStart="10dp"
                android:paddingTop="3dp"
                android:paddingEnd="10dp"
                android:paddingBottom="3dp"
                android:text="Mua xe"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRequestStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="⏳ Chờ xác nhận"
                android:textColor="#FF9800"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRequestTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="vừa xong"
                android:textColor="@color/color_on_surface_tertiary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- TÊN XE -->
        <TextView
            android:id="@+id/tvRequestCarName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Toyota Vios 2020"
            android:textColor="@color/color_on_background"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- GIÁ XE -->
        <TextView
            android:id="@+id/tvRequestCarPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="450.000.000 VNĐ"
            android:textColor="#E53935"
            android:textSize="14sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/color_divider" />

        <!-- THÔNG TIN NGƯỜI MUA/THUÊ -->
        <TextView
            android:id="@+id/tvBuyerInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="👤  Người mua: Nguyễn Văn A"
            android:textColor="@color/color_on_surface_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvBuyerPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="📞  0901234567"
            android:textColor="@color/color_on_surface_secondary"
            android:textSize="13sp" />

        <!-- CCCD (chỉ hiện khi thuê xe) -->
        <TextView
            android:id="@+id/tvBuyerCCCD"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="🪪  CCCD: 123456789012"
            android:textColor="@color/color_on_surface_secondary"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- NGÀY THUÊ (chỉ hiện khi thuê xe) -->
        <TextView
            android:id="@+id/tvRentInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="📅  Thuê từ: 20/05/2026 | 3 ngày"
            android:textColor="@color/color_on_surface_secondary"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- GHI CHÚ -->
        <TextView
            android:id="@+id/tvRequestNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_hint_box"
            android:padding="10dp"
            android:text="💬  Ghi chú: ..."
            android:textColor="@color/color_on_surface_secondary"
            android:textSize="13sp" />

        <!-- 2 NÚT XÁC NHẬN / TỪ CHỐI -->
        <LinearLayout
            android:id="@+id/layoutActionButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirm"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#4CAF50"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="✅ Xác nhận"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:backgroundTint="#F44336"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="❌ Từ chối"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />
        </LinearLayout>

        <!-- Hiện khi đã xử lý -->
        <TextView
            android:id="@+id/tvDoneLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Đã xử lý"
            android:textColor="@color/color_on_surface_tertiary"
            android:textSize="13sp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
