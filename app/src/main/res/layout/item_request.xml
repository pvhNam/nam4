<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- LOẠI YÊU CẦU + TRẠNG THÁI -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvRequestType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mua xe"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="#4CAF50"
                android:paddingStart="8dp" android:paddingEnd="8dp"
                android:paddingTop="3dp" android:paddingBottom="3dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvRequestStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏳ Chờ xác nhận"
                android:textColor="#FF9800"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvRequestTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="vừa xong"
                android:textColor="@color/color_on_surface_tertiary"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- TÊN XE -->
        <TextView
            android:id="@+id/tvRequestCarName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Toyota Vios 2020"
            android:textColor="@color/color_on_surface"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <!-- GIÁ XE -->
        <TextView
            android:id="@+id/tvRequestCarPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="450.000.000 VNĐ"
            android:textColor="#E53935"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <!-- THÔNG TIN NGƯỜI MUA/THUÊ -->
        <TextView
            android:id="@+id/tvBuyerInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤  Người mua: Nguyễn Văn A"
            android:textColor="@color/color_on_surface_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvBuyerPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📞  0901234567"
            android:textColor="@color/color_on_surface_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"/>

        <!-- CCCD (chỉ hiện khi thuê xe) -->
        <TextView
            android:id="@+id/tvBuyerCCCD"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🪪  CCCD: 123456789012"
            android:textColor="@color/color_on_surface_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"
            android:visibility="gone"/>

        <!-- NGÀY THUÊ (chỉ hiện khi thuê xe) -->
        <TextView
            android:id="@+id/tvRentInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅  Thuê từ: 20/05/2026 | 3 ngày"
            android:textColor="@color/color_on_surface_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"
            android:visibility="gone"/>

        <!-- GHI CHÚ -->
        <TextView
            android:id="@+id/tvRequestNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💬  Ghi chú: ..."
            android:textColor="@color/color_on_surface_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="12dp"/>

        <!-- 2 NÚT XÁC NHẬN / TỪ CHỐI -->
        <LinearLayout
            android:id="@+id/layoutActionButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnConfirm"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="✅ Xác nhận"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"/>

            <Button
                android:id="@+id/btnReject"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="❌ Từ chối"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#F44336"/>
        </LinearLayout>

        <!-- Hiện khi đã xử lý -->
        <TextView
            android:id="@+id/tvDoneLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đã xử lý"
            android:textColor="@color/color_on_surface_tertiary"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>