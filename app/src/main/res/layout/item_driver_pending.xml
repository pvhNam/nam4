<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="10dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_dp_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên tài xế"
            android:textColor="#1A1A1A"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_dp_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="CCCD · GPLX · Loại xe"
            android:textColor="#555555"
            android:textSize="13sp" />

        <!-- Ảnh giấy tờ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <ImageView
                android:id="@+id/iv_dp_cccd"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="#ECEFF1"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_report_image" />

            <ImageView
                android:id="@+id/iv_dp_license"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="#ECEFF1"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_report_image" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btn_dp_reject"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#E53935"
                android:text="Từ chối"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                app:cornerRadius="10dp" />

            <Button
                android:id="@+id/btn_dp_approve"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:backgroundTint="#2E7D32"
                android:text="Duyệt"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                app:cornerRadius="10dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
