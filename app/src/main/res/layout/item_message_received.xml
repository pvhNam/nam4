<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="4dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_marginEnd="60dp"
        android:gravity="start"
        android:orientation="vertical">

        <!-- Nội dung text -->
        <TextView
            android:id="@+id/tv_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_message_received"
            android:padding="12dp"
            android:text="Nội dung tin nhắn nhận được"
            android:textColor="@color/color_on_surface"
            android:textSize="15sp" />

        <!-- Ảnh / Thumbnail video đính kèm -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_image"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="2dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/iv_message_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <!-- Icon ▶ hiện khi là video -->
                <ImageView
                    android:id="@+id/iv_play_icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_blue"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_media_play"
                    android:visibility="gone"
                    app:tint="#FFFFFF" />
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Thời gian + menu 3 chấm -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14:31"
                android:textColor="@color/color_on_surface_tertiary"
                android:textSize="11sp" />

            <!-- Nút menu 3 chấm: Chuyển tiếp / Báo cáo -->
            <TextView
                android:id="@+id/btn_message_more"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="⋮"
                android:textColor="@color/color_on_surface_tertiary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>