<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginTop="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Hàng khách hàng -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <FrameLayout
                android:id="@+id/box_trip_avatar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_circle_soft"
                android:backgroundTint="@color/driver_surface_blue">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_dnav_profile"
                    app:tint="@color/driver_primary" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_trip_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_pill_round"
                android:backgroundTint="@color/driver_surface_blue"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="Khách mới"
                android:textColor="@color/driver_primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="10dp"
                android:layout_toStartOf="@id/tv_trip_badge"
                android:layout_toEndOf="@id/box_trip_avatar"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_trip_customer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Khách hàng"
                    android:textColor="@color/driver_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:src="@drawable/ic_star"
                        app:tint="@color/driver_orange" />

                    <TextView
                        android:id="@+id/tv_trip_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="4.9"
                        android:textColor="@color/driver_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>

        <!-- Trạng thái (cho lịch sử) -->
        <TextView
            android:id="@+id/tv_trip_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_pill_round"
            android:backgroundTint="@color/driver_green_bg"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:text="Hoàn thành"
            android:textColor="@color/driver_green"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Điểm đón -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_dot"
                android:backgroundTint="@color/driver_green" />

            <TextView
                android:id="@+id/tv_trip_pickup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Điểm đón"
                android:textColor="@color/driver_text"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Điểm đến -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_dot"
                android:backgroundTint="@color/driver_red" />

            <TextView
                android:id="@+id/tv_trip_dest"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Điểm đến"
                android:textColor="@color/driver_text"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Quãng đường + giá -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tv_trip_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="6.2 km · 18 phút"
                android:textColor="@color/driver_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_trip_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="0đ"
                android:textColor="@color/driver_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_trip_primary"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/driver_primary"
            android:text="Nhận chuyến"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_trip_secondary"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="8dp"
            android:text="Bỏ qua"
            android:textColor="@color/driver_text_secondary"
            app:cornerRadius="12dp"
            app:strokeColor="@color/driver_divider" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
