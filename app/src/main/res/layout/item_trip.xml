<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="10dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Hàng trên: loại xe + trạng thái -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_trip_cartype"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4 chỗ"
                android:textColor="#1A1A1A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_trip_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="#FFF3E0"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="Chờ nhận"
                android:textColor="#E65100"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tv_trip_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Theo quãng đường"
            android:textColor="#1976D2"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_trip_route"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Đón: ...\nĐến: ..."
            android:textColor="#444444"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_trip_customer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Khách: ..."
            android:textColor="#757575"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_trip_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="0 đ"
            android:textColor="#E65100"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_trip_action"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/driver_primary"
            android:text="Nhận chuyến"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="10dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
