<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng bài cho thuê"
            android:textColor="#1A1A1A"
            android:textSize="20sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView style="@style/DriverFieldLabel" android:text="Loại bài đăng" />

                <RadioGroup
                    android:id="@+id/rg_post_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rb_with_car"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="Cho thuê xe có tài xế"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/rb_driver_only"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cho thuê người lái (lái thuê)"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp" />
                </RadioGroup>

                <TextView style="@style/DriverFieldLabel" android:layout_marginTop="12dp" android:text="Tiêu đề tin" />
                <EditText
                    android:id="@+id/et_post_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="VD: Toyota Vios 2022 kèm tài xế"
                    android:inputType="text"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp" />

                <TextView style="@style/DriverFieldLabel" android:layout_marginTop="12dp" android:text="Loại xe" />
                <EditText
                    android:id="@+id/et_post_cartype"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="VD: Sedan 4 chỗ"
                    android:inputType="text"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp" />

                <TextView style="@style/DriverFieldLabel" android:layout_marginTop="12dp" android:text="Giá theo ngày (đ/ngày)" />
                <EditText
                    android:id="@+id/et_post_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="VD: 1.500.000"
                    android:inputType="number"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp" />

                <TextView style="@style/DriverFieldLabel" android:layout_marginTop="12dp" android:text="Giá theo chuyến (đ/km) — để trống nếu không nhận theo chuyến" />
                <EditText
                    android:id="@+id/et_post_price_km"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="VD: 12.000"
                    android:inputType="number"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp" />

                <TextView style="@style/DriverFieldLabel" android:layout_marginTop="12dp" android:text="Khu vực" />
                <EditText
                    android:id="@+id/et_post_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="VD: TP. Hồ Chí Minh"
                    android:inputType="text"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp" />

                <TextView style="@style/DriverFieldLabel" android:layout_marginTop="12dp" android:text="Mô tả thêm" />
                <EditText
                    android:id="@+id/et_post_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:hint="Kinh nghiệm lái, phạm vi hoạt động, lưu ý..."
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp" />

                <TextView style="@style/DriverFieldLabel" android:layout_marginTop="12dp" android:text="Ảnh minh hoạ" />

                <HorizontalScrollView
                    android:id="@+id/scroll_post_previews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:scrollbars="none"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/layout_post_previews"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <Button
                    android:id="@+id/btn_post_pick_image"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#E3F2FD"
                    android:text="Chọn ảnh (có thể chọn nhiều)"
                    android:textColor="#2A70DE"
                    android:textStyle="bold"
                    app:cornerRadius="10dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btn_post_submit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="@color/driver_primary"
            android:text="Đăng bài"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>
