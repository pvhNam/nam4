<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/lg_glass_fill_strong"
    app:strokeColor="@color/lg_glass_stroke"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Avatar -->
        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp">
            <TextView
                android:id="@+id/tvConvAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/bg_circle_blue"/>
            <ImageView
                android:id="@+id/ivConvAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp">

            <TextView
                android:id="@+id/tvConvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#1A1A2E"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvConvCarName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/lg_accent"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvConvLastMsg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Chấm xanh chưa đọc (giống Messenger) -->
        <View
            android:id="@+id/viewConvUnreadDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_dot"
            android:backgroundTint="#0084FF"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>