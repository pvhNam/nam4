<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="130dp">

            <ImageView
                android:id="@+id/ivCarRental"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/color_image_placeholder"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery" />

            <ImageView
                android:id="@+id/iv_favorite_rental"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_scrim"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Yêu thích"
                android:padding="7dp"
                android:src="@drawable/ic_heart_outline" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/tvCarRentalName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Hyundai Accent 2022"
                android:textColor="@color/color_on_background"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCarRentalPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="800.000đ / ngày"
                android:textColor="#D32F2F"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCarRentalInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Quận 1, TP.HCM • Tự động"
                android:textColor="@color/color_on_surface_secondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnRentNow"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:clickable="false"
                android:duplicateParentState="true"
                android:backgroundTint="#4CAF50"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text="THUÊ NGAY"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="6dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
