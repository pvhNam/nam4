<?xml version="1.0" encoding="utf-8"?>
<!--
    item_chat_notification.xml
    Layout cho mỗi item trong tab Thông báo (NotifAdapter).

    Yêu cầu 1: CardView bo góc 20dp, elevation đổ bóng nhẹ → trông giống card Messenger.
    Yêu cầu 2: Hiện "Người A muốn mua/thuê xe B" qua tv_notif_body (data đã build bởi ChatNotificationHelper).
    Yêu cầu 3: Chấm xanh (view_unread_dot) hiện khi chưa đọc; sau khi bấm vào tự ẩn.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_notification"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:gravity="center_vertical">

        <!-- ── Avatar + badge icon loại thông báo ── -->
        <FrameLayout
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_marginEnd="14dp">

            <!-- Chữ cái đầu tên người gửi (fallback khi chưa có ảnh) -->
            <TextView
                android:id="@+id/tv_notif_avatar"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:background="@drawable/bg_circle_blue" />

            <!-- Ảnh avatar thật (Glide load → VISIBLE, tv_notif_avatar → GONE) -->
            <ImageView
                android:id="@+id/iv_notif_avatar"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:background="@drawable/bg_circle_blue"
                android:clipToOutline="true" />

            <!-- Badge nhỏ góc dưới phải: icon 💬 hoặc 🔔 -->
            <FrameLayout
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_circle_blue"
                android:backgroundTint="#1565C0">

                <TextView
                    android:id="@+id/tv_notif_type_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="💬"
                    android:textSize="11sp" />
            </FrameLayout>
        </FrameLayout>

        <!-- ── Nội dung chính ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- "Tin nhắn từ Nguyễn A" -->
            <TextView
                android:id="@+id/tv_notif_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#111111"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- "Nguyễn A muốn mua xe Toyota Camry" -->
            <TextView
                android:id="@+id/tv_notif_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="#444444"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Thời gian gửi -->
            <TextView
                android:id="@+id/tv_notif_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textColor="#AAAAAA"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- ── Chấm xanh = chưa đọc ── -->
        <View
            android:id="@+id/view_unread_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_dot"
            android:backgroundTint="#2F54D4"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>