<?xml version="1.0" encoding="utf-8"?>
<!--
    item_chat_notification.xml
    Style giống Messenger: avatar tròn, tên đậm, preview tin nhắn, thời gian, chấm xanh chưa đọc.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_notification"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:gravity="center_vertical">

        <!-- ── Avatar ── -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="14dp">

            <!-- Chữ cái đầu (fallback) -->
            <TextView
                android:id="@+id/tv_notif_avatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:background="@drawable/bg_circle_blue" />

            <!-- Ảnh avatar thật -->
            <ImageView
                android:id="@+id/iv_notif_avatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:background="@drawable/bg_circle_blue"
                android:clipToOutline="true" />

            <!-- Badge 💬 góc dưới phải -->
            <FrameLayout
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_circle_blue"
                android:backgroundTint="#0084FF">

                <TextView
                    android:id="@+id/tv_notif_type_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="💬"
                    android:textSize="10sp" />
            </FrameLayout>
        </FrameLayout>

        <!-- ── Nội dung ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Tên người gửi -->
            <TextView
                android:id="@+id/tv_notif_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Nội dung tin nhắn mới nhất -->
            <TextView
                android:id="@+id/tv_notif_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#65676B"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Thời gian -->
            <TextView
                android:id="@+id/tv_notif_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#65676B"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- ── Chấm xanh chưa đọc (giống Messenger) ── -->
        <View
            android:id="@+id/view_unread_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_dot"
            android:backgroundTint="#0084FF"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>