<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp"
    android:elevation="1dp">

    <!-- Row chính: ảnh + thông tin + trạng thái -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_car_thumb"
            android:layout_width="72dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="#EEEEEE"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_car_admin_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên xe"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_car_admin_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giá"
                android:textColor="#C62828"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_car_admin_seller"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Người đăng"
                android:textColor="#757575"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_car_admin_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="active"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_car_admin_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="sale"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Nút hành động -->
    <LinearLayout
        android:id="@+id/layout_car_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_delete_car"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Xóa"
            android:textSize="12sp"
            android:textColor="#757575"
            android:backgroundTint="#EEEEEE" />

        <Button
            android:id="@+id/btn_reject_car"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Từ chối"
            android:textSize="12sp"
            android:textColor="@color/admin_primary"
            android:backgroundTint="@color/role_admin_bg" />

        <Button
            android:id="@+id/btn_approve_car"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:text="Duyệt"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/admin_primary" />
    </LinearLayout>

</LinearLayout>
