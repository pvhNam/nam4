<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_dp_avatar"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:src="@drawable/ic_driver_avatar_placeholder"
                    app:civ_border_color="@color/driver_primary"
                    app:civ_border_width="2dp" />

                <TextView
                    android:id="@+id/tv_dp_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Tài xế"
                    android:textColor="#1A1A1A"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@color/driver_primary"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="3dp"
                    android:text="TÀI XẾ"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Thống kê doanh thu theo ngày / tháng / năm (chọn kỳ cụ thể) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thống kê doanh thu"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Chọn chế độ: Ngày / Tháng / Năm -->
                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggle_rev_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:checkedButton="@id/btn_mode_month"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_mode_day"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Ngày"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_mode_month"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tháng"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_mode_year"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Năm"
                        android:textSize="13sp" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!-- Thanh điều hướng kỳ: ◀  [nhãn kỳ, bấm để mở lịch]  ▶ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btn_period_prev"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Kỳ trước"
                        android:src="@drawable/ic_back"
                        app:tint="@color/driver_primary" />

                    <TextView
                        android:id="@+id/tv_period_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:drawablePadding="6dp"
                        android:gravity="center"
                        android:paddingVertical="8dp"
                        android:text="Tháng 6/2026"
                        android:textColor="#1A1A1A"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btn_period_next"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Kỳ sau"
                        android:rotation="180"
                        android:src="@drawable/ic_back"
                        app:tint="@color/driver_primary" />
                </LinearLayout>

                <!-- Kết quả doanh thu của kỳ đã chọn -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@color/stat_card_orange"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Doanh thu"
                        android:textColor="@color/driver_dark"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tv_rev_selected"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="0 đ"
                        android:textColor="@color/driver_dark"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_trips_selected"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="0 chuyến hoàn thành"
                        android:textColor="@color/driver_primary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView style="@style/DriverFieldLabel" android:text="Loại xe lái" />
                <TextView android:id="@+id/tv_dp_cartype" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#1A1A1A" android:textSize="15sp" android:layout_marginBottom="12dp"/>

                <TextView style="@style/DriverFieldLabel" android:text="Số CCCD" />
                <TextView android:id="@+id/tv_dp_cccd" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#1A1A1A" android:textSize="15sp" android:layout_marginBottom="12dp"/>

                <TextView style="@style/DriverFieldLabel" android:text="Số bằng lái" />
                <TextView android:id="@+id/tv_dp_license" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#1A1A1A" android:textSize="15sp" android:layout_marginBottom="4dp"/>

                <TextView style="@style/DriverFieldLabel" android:text="Số điện thoại" />
                <TextView android:id="@+id/tv_dp_phone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#1A1A1A" android:textSize="15sp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btn_dp_switch_user"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#2A70DE"
            android:text="Chuyển sang chế độ người dùng"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <Button
            android:id="@+id/btn_dp_logout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#E53935"
            android:text="Đăng xuất"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>
