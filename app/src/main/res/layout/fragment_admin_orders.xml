<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:orientation="vertical"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Quản lý đơn hàng"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_admin_order_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 đơn"
                android:textColor="#757575"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Tab lọc -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btn_order_tab_pending"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Chờ duyệt"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/admin_primary" />

            <Button
                android:id="@+id/btn_order_tab_confirmed"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Đã xác nhận"
                android:textSize="12sp"
                android:textColor="@color/admin_primary"
                android:backgroundTint="@color/role_admin_bg" />

            <Button
                android:id="@+id/btn_order_tab_all"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:text="Tất cả"
                android:textSize="12sp"
                android:textColor="@color/admin_primary"
                android:backgroundTint="@color/role_admin_bg" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_admin_empty_orders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="32dp"
        android:gravity="center"
        android:text="Không có đơn hàng nào"
        android:textColor="#9E9E9E"
        android:textSize="15sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_admin_orders"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false" />

</LinearLayout>
