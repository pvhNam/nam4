<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8">

    <LinearLayout
        android:id="@+id/layout_not_logged_in"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="🚗"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Đăng nhập để xem tài khoản"
            android:textColor="#757575"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_login"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:backgroundTint="#1976D2"
            android:text="Đăng nhập"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn_register"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:backgroundTint="#90A4AE"
            android:text="Đăng ký"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/layout_logged_in"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <ScrollView
            android:id="@+id/layout_main_profile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="100dp"> <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="150dp"
                app:cardBackgroundColor="#2A70DE"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:layout_marginTop="-20dp"/>

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_user_profile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="-45dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp">

                        <ImageView
                            android:id="@+id/iv_avatar_main"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@android:drawable/ic_menu_report_image"
                            android:scaleType="centerCrop"
                            android:layout_centerVertical="true" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toEndOf="@id/iv_avatar_main"
                            android:layout_marginStart="14dp"
                            android:layout_centerVertical="true">

                            <TextView
                                android:id="@+id/tv_profile_name_main"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hoài Nam"
                                android:textColor="#1A1A1A"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="4dp">

                                <ImageView
                                    android:id="@+id/iv_verified_icon"
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:layout_marginEnd="4dp"
                                    android:src="@drawable/ic_verified"
                                    android:visibility="gone" /> <TextView
                                android:id="@+id/tv_phone_verified_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chưa xác thực số điện thoại"
                                android:textColor="#E53935"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#2A70DE"
                            android:textSize="26sp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:id="@+id/ic1"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_register_rent_car"
                                android:layout_centerVertical="true"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Đăng kí cho thuê xe"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp"
                                android:layout_toEndOf="@id/ic1"
                                android:layout_marginStart="12dp"
                                android:layout_centerVertical="true"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="›"
                                android:textColor="#2A70DE"
                                android:textSize="22sp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true" />
                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:background="#E8E8E8"
                            android:layout_marginHorizontal="16dp"/>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:id="@+id/ic2"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_favourite_cars"
                                android:layout_centerVertical="true"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Xe yêu thích"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp"
                                android:layout_toEndOf="@id/ic2"
                                android:layout_marginStart="12dp"
                                android:layout_centerVertical="true"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="›"
                                android:textColor="#2A70DE"
                                android:textSize="22sp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true" />
                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:background="#E8E8E8"
                            android:layout_marginHorizontal="16dp"/>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:id="@+id/ic3"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_location"
                                android:layout_centerVertical="true"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vị trí của tôi"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp"
                                android:layout_toEndOf="@id/ic3"
                                android:layout_marginStart="12dp"
                                android:layout_centerVertical="true"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="›"
                                android:textColor="#2A70DE"
                                android:textSize="22sp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true" />
                        </RelativeLayout>
                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E8E8E8" android:layout_marginHorizontal="16dp"/>

                        <RelativeLayout android:layout_width="match_parent" android:layout_height="48dp" android:paddingHorizontal="16dp">
                            <TextView android:id="@+id/ic4" android:layout_width="24dp" android:layout_height="24dp" android:text="⭐" android:textSize="16sp" android:gravity="center" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bài đánh giá" android:textColor="#1A1A1A" android:textSize="14sp" android:layout_toEndOf="@id/ic4" android:layout_marginStart="12dp" android:layout_centerVertical="true" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#2A70DE" android:textSize="22sp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" />
                        </RelativeLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RelativeLayout android:layout_width="match_parent" android:layout_height="48dp" android:paddingHorizontal="16dp">
                            <TextView android:id="@+id/ic5" android:layout_width="24dp" android:layout_height="24dp" android:text="🎁" android:textSize="16sp" android:gravity="center" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Quà tặng" android:textColor="#1A1A1A" android:textSize="14sp" android:layout_toEndOf="@id/ic5" android:layout_marginStart="12dp" android:layout_centerVertical="true" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#2A70DE" android:textSize="22sp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" />
                        </RelativeLayout>
                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E8E8E8" android:layout_marginHorizontal="16dp"/>

                        <RelativeLayout android:layout_width="match_parent" android:layout_height="48dp" android:paddingHorizontal="16dp">
                            <TextView android:id="@+id/ic6" android:layout_width="24dp" android:layout_height="24dp" android:text="👥" android:textSize="16sp" android:gravity="center" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Giới thiệu bạn mới" android:textColor="#1A1A1A" android:textSize="14sp" android:layout_toEndOf="@id/ic6" android:layout_marginStart="12dp" android:layout_centerVertical="true" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#2A70DE" android:textSize="22sp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" />
                        </RelativeLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RelativeLayout android:layout_width="match_parent" android:layout_height="48dp" android:paddingHorizontal="16dp">
                            <TextView android:id="@+id/ic7" android:layout_width="24dp" android:layout_height="24dp" android:text="🛡️" android:textSize="16sp" android:gravity="center" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chính sách bảo mật" android:textColor="#1A1A1A" android:textSize="14sp" android:layout_toEndOf="@id/ic7" android:layout_marginStart="12dp" android:layout_centerVertical="true" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#2A70DE" android:textSize="22sp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" />
                        </RelativeLayout>
                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E8E8E8" android:layout_marginHorizontal="16dp"/>

                        <RelativeLayout android:layout_width="match_parent" android:layout_height="48dp" android:paddingHorizontal="16dp">
                            <TextView android:id="@+id/ic8" android:layout_width="24dp" android:layout_height="24dp" android:text="❓" android:textSize="16sp" android:gravity="center" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trung tâm hỗ trợ" android:textColor="#1A1A1A" android:textSize="14sp" android:layout_toEndOf="@id/ic8" android:layout_marginStart="12dp" android:layout_centerVertical="true" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#2A70DE" android:textSize="22sp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" />
                        </RelativeLayout>
                        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E8E8E8" android:layout_marginHorizontal="16dp"/>

                        <RelativeLayout android:layout_width="match_parent" android:layout_height="48dp" android:paddingHorizontal="16dp">
                            <TextView android:id="@+id/ic9" android:layout_width="24dp" android:layout_height="24dp" android:text="ℹ️" android:textSize="16sp" android:gravity="center" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Về chúng tôi" android:textColor="#1A1A1A" android:textSize="14sp" android:layout_toEndOf="@id/ic9" android:layout_marginStart="12dp" android:layout_centerVertical="true" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#2A70DE" android:textSize="22sp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" />
                        </RelativeLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btn_switch_driver"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="#2A70DE"
                    android:text="Chuyển đổi thành tài xế"
                    android:textColor="#FFFFFF"
                    android:visibility="gone"
                    app:cornerRadius="12dp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_logout"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#E53935"
                    android:text="Đăng xuất"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="12dp"
                    android:textStyle="bold" />

            </LinearLayout>
        </ScrollView>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_account_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:id="@+id/banner_settings"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                app:cardBackgroundColor="#2A70DE"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="-20dp"/>

            <ImageView
                android:id="@+id/btn_back_to_main"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                android:padding="8dp"
                app:tint="#FFFFFF"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:clickable="true"
                android:focusable="true" />

            <FrameLayout
                android:id="@+id/avatar_container"
                android:layout_width="90dp"
                android:layout_height="90dp"
                app:layout_constraintTop_toBottomOf="@id/banner_settings"
                app:layout_constraintBottom_toBottomOf="@id/banner_settings"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.cardview.widget.CardView
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="43dp"
                    app:cardElevation="2dp">
                    <ImageView
                        android:id="@+id/iv_avatar_settings"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/ic_menu_report_image"
                        android:scaleType="centerCrop"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/iv_change_avatar_trigger"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|center_horizontal"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="4dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/ic_menu_camera"
                        android:padding="5dp"
                        app:tint="#2A70DE"/>
                </androidx.cardview.widget.CardView>
            </FrameLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/avatar_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/menu_personal_info"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">
                        <TextView android:id="@+id/s_ic1" android:layout_width="24dp" android:layout_height="24dp" android:text="👤" android:textSize="16sp" android:gravity="center" android:layout_centerVertical="true"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thông tin cá nhân" android:textColor="#1A1A1A" android:textSize="15sp" android:layout_toEndOf="@id/s_ic1" android:layout_marginStart="14dp" android:layout_centerVertical="true" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#2A70DE" android:textSize="24sp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" />
                    </RelativeLayout>
                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E0E0E0" android:layout_marginHorizontal="16dp"/>

                    <RelativeLayout
                        android:id="@+id/menu_register_driver"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">
                        <TextView android:id="@+id/s_ic2" android:layout_width="24dp" android:layout_height="24dp" android:text="🚖" android:textSize="16sp" android:gravity="center" android:layout_centerVertical="true"/>
                        <TextView android:id="@+id/tv_register_driver_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đăng ký làm tài xế" android:textColor="#1A1A1A" android:textSize="15sp" android:layout_toEndOf="@id/s_ic2" android:layout_marginStart="14dp" android:layout_centerVertical="true" android:textStyle="bold"/>
                        <TextView android:id="@+id/tv_driver_status_hint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#2A70DE" android:textSize="24sp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" />
                    </RelativeLayout>
                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E0E0E0" android:layout_marginHorizontal="16dp"/>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp" android:paddingHorizontal="16dp">
                        <TextView android:id="@+id/s_ic3" android:layout_width="24dp" android:layout_height="24dp" android:text="⚙️" android:textSize="16sp" android:gravity="center" android:layout_centerVertical="true"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bảo mật &amp; liên kết" android:textColor="#1A1A1A" android:textSize="15sp" android:layout_toEndOf="@id/s_ic3" android:layout_marginStart="14dp" android:layout_centerVertical="true" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#2A70DE" android:textSize="24sp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" />
                    </RelativeLayout>
                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E0E0E0" android:layout_marginHorizontal="16dp"/>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp" android:paddingHorizontal="16dp">
                        <TextView android:id="@+id/s_ic4" android:layout_width="24dp" android:layout_height="24dp" android:text="💳" android:textSize="16sp" android:gravity="center" android:layout_centerVertical="true"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phương thức thanh toán" android:textColor="#1A1A1A" android:textSize="15sp" android:layout_toEndOf="@id/s_ic4" android:layout_marginStart="14dp" android:layout_centerVertical="true" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#2A70DE" android:textSize="24sp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" />
                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>


        <RelativeLayout
            android:id="@+id/layout_personal_info"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:visibility="gone">

            <RelativeLayout
                android:id="@+id/top_bar_info"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingHorizontal="16dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_back_to_settings"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_centerVertical="true"
                    app:cardBackgroundColor="#F5F6F8"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="‹"
                        android:textColor="#2A70DE"
                        android:textSize="26sp"
                        android:layout_gravity="center"
                        android:layout_marginTop="-2dp"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin cá nhân"
                    android:textColor="#1A1A1A"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_centerInParent="true"/>
            </RelativeLayout>

            <Button
                android:id="@+id/btn_save_personal_info"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_alignParentBottom="true"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="340dp"
                android:backgroundTint="#2A70DE"
                android:text="Lưu"
                android:textColor="#FFFFFF"
                app:cornerRadius="12dp"
                android:textStyle="bold" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/top_bar_info"
                android:layout_above="@id/btn_save_personal_info"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Họ và tên" android:textColor="#888888" android:textSize="13sp"/>
                    <EditText
                        android:id="@+id/edt_info_name"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="16dp"
                        android:background="@android:drawable/editbox_background"
                        android:paddingHorizontal="14dp"
                        android:text="Hoài Nam"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp"
                        android:inputType="textPersonName"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ngày sinh" android:textColor="#888888" android:textSize="13sp"/>
                    <EditText
                        android:id="@+id/edt_info_dob"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="16dp"
                        android:background="@android:drawable/editbox_background"
                        android:paddingHorizontal="14dp"
                        android:hint="dd/mm/yyyy"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp"
                        android:inputType="date"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Giới tính" android:textColor="#888888" android:textSize="13sp"/>
                    <EditText
                        android:id="@+id/edt_info_gender"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="16dp"
                        android:background="@android:drawable/editbox_background"
                        android:paddingHorizontal="14dp"
                        android:text="Nam"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp"
                        android:inputType="text"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Số điện thoại" android:textColor="#888888" android:textSize="13sp"/>
                    <EditText
                        android:id="@+id/edt_info_phone"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@android:drawable/editbox_background"
                        android:paddingHorizontal="14dp"
                        android:text="0xxxxxxxxx"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp"
                        android:inputType="phone"/>

                </LinearLayout>
            </ScrollView>

        </RelativeLayout>

    </FrameLayout>

</FrameLayout>
