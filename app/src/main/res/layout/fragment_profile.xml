<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- CHƯA ĐĂNG NHẬP -->
    <LinearLayout
        android:id="@+id/layout_not_logged_in"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚗"
            android:textSize="48sp"
            android:layout_gravity="center"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng nhập để xem tài khoản"
            android:textSize="16sp"
            android:textColor="@color/color_on_surface_secondary"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btn_login"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:text="Đăng nhập"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btn_register"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:text="Đăng ký"
            android:backgroundTint="#90A4AE"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- ĐÃ ĐĂNG NHẬP -->
    <LinearLayout
        android:id="@+id/layout_logged_in"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- THÔNG TIN TÀI KHOẢN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="20dp"
            android:paddingBottom="14dp"
            android:background="@color/color_surface_variant">

            <!-- AVATAR + NÚT CHỌN ẢNH -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">

                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:background="@color/color_image_placeholder"
                    android:scaleType="centerCrop"/>

                <!-- Overlay camera icon ở góc dưới phải -->
                <ImageView
                    android:id="@+id/iv_change_avatar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="bottom|end"
                    android:src="@android:drawable/ic_menu_camera"
                    android:background="#1976D2"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tv_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/color_on_background"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tv_profile_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_on_surface_secondary"
                android:textSize="14sp"
                android:layout_marginTop="2dp"/>

            <Button
                android:id="@+id/btn_logout"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Đăng xuất"
                android:textSize="13sp"
                android:backgroundTint="#E53935"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="20dp"/>
        </LinearLayout>

        <!-- 2 NÚT TAB -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:background="@color/color_surface">

            <Button
                android:id="@+id/btnTabMyCars"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Xe đã đăng"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"/>

            <Button
                android:id="@+id/btnTabMyOrders"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Lịch sử đơn"
                android:textSize="13sp"
                android:textColor="#1976D2"
                android:backgroundTint="@color/color_tab_inactive_bg"/>
        </LinearLayout>

        <!-- TAB 1: XE ĐÃ ĐĂNG -->
        <LinearLayout
            android:id="@+id/layoutTabMyCars"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Bộ lọc -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:background="@color/color_surface">

                <Button
                    android:id="@+id/btn_filter_all"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:text="Tất cả"
                    android:textSize="12sp"
                    android:backgroundTint="#1976D2"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_filter_sale"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:text="Cần bán"
                    android:textSize="12sp"
                    android:backgroundTint="#90A4AE"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_filter_rental"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:text="Cho thuê"
                    android:textSize="12sp"
                    android:backgroundTint="#90A4AE"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_car_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tin đã đăng: 0"
                android:textSize="13sp"
                android:textColor="@color/color_on_surface_secondary"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_my_cars"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/tv_empty_cars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bạn chưa đăng tin nào"
                android:gravity="center"
                android:textColor="@color/color_on_surface_tertiary"
                android:paddingVertical="40dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- TAB 2: LỊCH SỬ ĐƠN -->
        <LinearLayout
            android:id="@+id/layoutTabMyOrders"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvOrderCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đơn của tôi: 0"
                android:textSize="13sp"
                android:textColor="@color/color_on_surface_secondary"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMyOrders"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvEmptyOrders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bạn chưa có đơn nào"
                android:gravity="center"
                android:textColor="@color/color_on_surface_tertiary"
                android:paddingVertical="40dp"
                android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>