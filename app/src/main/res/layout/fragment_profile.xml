<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Chưa đăng nhập -->
    <LinearLayout
        android:id="@+id/layout_not_logged_in"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chào mừng bạn đến với app xe cũ"
            android:textSize="18sp"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btn_login"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Đăng nhập"
            android:backgroundTint="#1976D2"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btn_register"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Đăng ký"
            android:backgroundTint="@android:color/darker_gray" />
    </LinearLayout>

    <!-- Đã đăng nhập -->
    <LinearLayout
        android:id="@+id/layout_logged_in"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Thông tin tài khoản -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"
            android:background="#F5F5F5">

            <ImageView
                android:id="@+id/iv_avatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:background="@android:color/darker_gray"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/tv_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="20sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tv_profile_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/darker_gray"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_logout"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Đăng xuất"
                android:textSize="13sp"
                android:backgroundTint="#E53935"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="20dp" />
        </LinearLayout>

        <!-- Bộ lọc -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="@android:color/white">

            <Button
                android:id="@+id/btn_filter_all"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Tất cả"
                android:textSize="13sp"
                android:backgroundTint="#1976D2"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_filter_sale"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Cần bán"
                android:textSize="13sp"
                android:backgroundTint="#90A4AE"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_filter_rental"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Cho thuê"
                android:textSize="13sp"
                android:backgroundTint="#90A4AE" />
        </LinearLayout>

        <!-- Tin đang xem -->
        <TextView
            android:id="@+id/tv_car_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tin đã đăng: 0"
            android:textSize="13sp"
            android:textColor="@android:color/darker_gray"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp" />

        <!-- Danh sách xe -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_my_cars"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="4dp" />

        <!-- Trống -->
        <TextView
            android:id="@+id/tv_empty_cars"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bạn chưa đăng tin nào"
            android:gravity="center"
            android:textColor="@android:color/darker_gray"
            android:paddingVertical="40dp"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
