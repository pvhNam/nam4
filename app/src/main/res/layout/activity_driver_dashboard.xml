<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6F8"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/driver_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_driver_header"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingVertical="18dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.1"
                android:text="TÀI XẾ"
                android:textColor="#FFE0B2"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_driver_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang tải..."
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Công tắc Online/Offline -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginEnd="10dp">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_online"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="#FFFFFF"
                app:trackTint="#80FFFFFF" />

            <TextView
                android:id="@+id/tv_online_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Offline"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_driver_logout"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:text="Thoát"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            app:cornerRadius="20dp"
            app:rippleColor="#33FFFFFF"
            app:strokeColor="#80FFFFFF"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/driver_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/driver_bottom_nav"
        app:layout_constraintTop_toBottomOf="@id/driver_header" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/driver_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:background="@android:color/white"
        android:elevation="12dp"
        app:elevation="12dp"
        app:itemIconTint="@color/driver_nav_selector"
        app:itemRippleColor="@color/driver_nav_selector"
        app:itemTextColor="@color/driver_nav_selector"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_driver" />

</androidx.constraintlayout.widget.ConstraintLayout>
