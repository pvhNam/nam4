<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/driver_primary"
    android:fitsSystemWindows="true">

    <!-- Mỗi fragment tự vẽ header xanh của riêng nó (theo thiết kế driver1-5) -->
    <FrameLayout
        android:id="@+id/driver_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/driver_bottom_nav"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/driver_divider"
        app:layout_constraintBottom_toTopOf="@id/driver_bottom_nav" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/driver_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@android:color/white"
        android:elevation="14dp"
        app:elevation="14dp"
        app:itemIconTint="@color/driver_nav_selector"
        app:itemRippleColor="@color/driver_nav_selector"
        app:labelVisibilityMode="unlabeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_driver" />

</androidx.constraintlayout.widget.ConstraintLayout>
