<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/staff_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/staff_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NHÂN VIÊN"
                android:textColor="#B2DFDB"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tv_staff_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang tải..."
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_staff_logout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/staff_dark"
            android:text="Đăng xuất"
            android:textColor="@android:color/white"
            android:textSize="13sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/staff_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/staff_bottom_nav"
        app:layout_constraintTop_toBottomOf="@id/staff_header" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/staff_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@android:color/white"
        android:elevation="8dp"
        app:itemIconTint="@color/staff_primary"
        app:itemTextColor="@color/staff_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_staff" />

</androidx.constraintlayout.widget.ConstraintLayout>
