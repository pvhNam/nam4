<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Nhãn ô nhập trong form tài xế -->
    <style name="DriverFieldLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#888888</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Hàng lối tắt / menu của tài xế (icon + tiêu đề + phụ đề + mũi tên) -->
    <style name="DriverQuickRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:padding">15dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <style name="DriverQuickRowText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">14dp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="DriverQuickRowTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/driver_text</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DriverQuickRowSub">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">1dp</item>
        <item name="android:textColor">@color/driver_text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="DriverChevron">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">18dp</item>
        <item name="android:src">@drawable/ic_back</item>
        <item name="android:rotation">180</item>
        <item name="android:tint">#B0B7C3</item>
    </style>

    <!-- Nhãn hệ số giá (vùng nhu cầu) -->
    <style name="SurgeChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_pill_round</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">4dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:elevation">3dp</item>
    </style>

    <style name="DriverZoneRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:padding">10dp</item>
    </style>

    <style name="DriverZoneName">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:textColor">@color/driver_text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Cột thống kê trong thẻ thu nhập (gradient xanh) -->
    <style name="EarningStatCol">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="EarningStatValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="EarningStatLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:textColor">#D6E2FF</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="EarningDivider">
        <item name="android:layout_width">1dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:background">#33FFFFFF</item>
    </style>

    <!-- Nhóm thẻ menu trang Cá nhân -->
    <style name="DriverMenuGroup">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">14dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="DriverMenuGroupInner">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:divider">?android:attr/listDivider</item>
        <item name="android:showDividers">middle</item>
    </style>

    <style name="DriverMenuIcon">
        <item name="android:layout_width">22dp</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:tint">@color/driver_primary</item>
    </style>

    <style name="DriverMenuTitle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">14dp</item>
        <item name="android:textColor">@color/driver_text</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- Ô nhập trong form tài xế -->
    <style name="DriverInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:background">@android:drawable/editbox_background</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:textColor">#1A1A1A</item>
        <item name="android:textSize">15sp</item>
    </style>

</resources>