<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Base.Theme.DOANMB" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Màu nhấn teal Liquid Glass (đồng nhất toàn app khách hàng) -->
        <item name="colorPrimary">@color/lg_accent</item>
        <item name="colorPrimaryVariant">@color/lg_accent_dark</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/lg_accent</item>
        <item name="colorControlActivated">@color/lg_accent</item>
        <item name="android:windowBackground">@color/color_background</item>
        <item name="android:textColorHint">@color/color_hint</item>
        <!-- Tắt ripple mặc định của BottomNav để dùng background tùy chỉnh -->
        <item name="bottomNavigationStyle">@style/BottomNavPill</item>
    </style>

    <style name="Theme.DOANMB" parent="Base.Theme.DOANMB" />

    <!-- Tài xế: giữ tông xanh riêng (không theo teal) -->
    <style name="Theme.DOANMB.Driver" parent="Base.Theme.DOANMB">
        <item name="colorPrimary">@color/driver_primary</item>
        <item name="colorPrimaryVariant">@color/driver_dark</item>
        <item name="colorControlActivated">@color/driver_primary</item>
    </style>

    <!-- Admin: giữ tông đỏ riêng -->
    <style name="Theme.DOANMB.Admin" parent="Base.Theme.DOANMB">
        <item name="colorPrimary">@color/admin_primary</item>
        <item name="colorPrimaryVariant">@color/admin_dark</item>
        <item name="colorControlActivated">@color/admin_primary</item>
    </style>

    <!-- Style cho BottomNavigation pill bo tròn -->
    <style name="BottomNavPill" parent="Widget.Material3.BottomNavigationView">
        <!-- Nền trong suốt: lớp kính do BlurView phía dưới đảm nhiệm -->
        <item name="android:background">@android:color/transparent</item>
        <item name="elevation">0dp</item>
        <item name="itemHorizontalTranslationEnabled">false</item>
        <item name="itemRippleColor">@color/ripple_nav</item>
        <item name="itemActiveIndicatorStyle">@style/NavActiveIndicator</item>
    </style>

    <!-- Indicator kính sáng cho item đang chọn (bong bóng trắng mờ) -->
    <style name="NavActiveIndicator" parent="@style/Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/lg_glass_fill_strong</item>
        <item name="android:width">44dp</item>
        <item name="android:height">32dp</item>
        <item name="shapeAppearance">@style/NavIndicatorShape</item>
    </style>

    <style name="NavIndicatorShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <style name="CircleImageOverlay">
        <item name="cornerSize">50%</item>
    </style>
    <style name="ReportBottomSheetTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/ReportBottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
    </style>

    <style name="ReportBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
        <item name="backgroundTint">#2C2C2C</item>
        <item name="shapeAppearance">@style/ReportBottomSheetShapeAppearance</item>
    </style>

    <style name="ReportBottomSheetShapeAppearance" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>