<?xml version="1.0" encoding="utf-8"?>
<!-- Đăng ký — Liquid Glass: nền gradient pastel + thẻ kính chứa form -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_liquid_glass"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp">

        <ImageView
            android:layout_width="160dp"
            android:layout_height="50dp"
            android:layout_marginBottom="18dp"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_carvia" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tạo tài khoản"
                android:textColor="@color/lg_text"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="22dp"
                android:text="Tham gia Carvia ngay hôm nay"
                android:textColor="@color/lg_text_secondary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_register_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_glass_input"
                android:hint="Họ và tên"
                android:inputType="textPersonName"
                android:paddingHorizontal="16dp"
                android:textColor="@color/lg_text"
                android:textColorHint="@color/lg_text_secondary" />

            <EditText
                android:id="@+id/et_register_phone"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_glass_input"
                android:hint="Số điện thoại"
                android:inputType="phone"
                android:paddingHorizontal="16dp"
                android:textColor="@color/lg_text"
                android:textColorHint="@color/lg_text_secondary" />

            <EditText
                android:id="@+id/et_register_email"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_glass_input"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="16dp"
                android:textColor="@color/lg_text"
                android:textColorHint="@color/lg_text_secondary" />

            <EditText
                android:id="@+id/et_register_password"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_glass_input"
                android:hint="Mật khẩu"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:textColor="@color/lg_text"
                android:textColorHint="@color/lg_text_secondary" />

            <EditText
                android:id="@+id/et_register_confirm_password"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="22dp"
                android:background="@drawable/bg_glass_input"
                android:hint="Xác nhận mật khẩu"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:textColor="@color/lg_text"
                android:textColorHint="@color/lg_text_secondary" />

            <Button
                android:id="@+id/btn_do_register"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="ĐĂNG KÝ"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/lg_accent"
                app:cornerRadius="26dp"
                app:strokeColor="@color/lg_glass_stroke"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã có tài khoản? "
                android:textColor="@color/lg_text_secondary" />

            <TextView
                android:id="@+id/tv_back_to_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng nhập"
                android:textColor="@color/lg_accent_text"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
