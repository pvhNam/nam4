<?xml version="1.0" encoding="utf-8"?>
<!-- Quên mật khẩu — Liquid Glass -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="28dp"
    android:gravity="center"
    android:background="@drawable/bg_liquid_glass">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_glass_card"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quên mật khẩu"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/lg_text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="22dp"
            android:text="Nhập email đã đăng ký, chúng tôi sẽ gửi hướng dẫn đặt lại mật khẩu."
            android:textSize="14sp"
            android:textColor="@color/lg_text_secondary" />

        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Nhập email đã đăng ký"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="16dp"
            android:textColor="@color/lg_text"
            android:textColorHint="@color/lg_text_secondary"
            android:background="@drawable/bg_glass_input"
            android:layout_marginBottom="22dp" />

        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Lấy lại mật khẩu"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="@color/lg_accent"
            app:cornerRadius="26dp"
            app:strokeColor="@color/lg_glass_stroke"
            app:strokeWidth="1dp" />
    </LinearLayout>
</LinearLayout>
