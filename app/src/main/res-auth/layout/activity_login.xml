<?xml version="1.0" encoding="utf-8"?>
<!-- Đăng nhập — Liquid Glass: nền gradient pastel + thẻ kính chứa form -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_liquid_glass"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <ImageView
            android:layout_width="180dp"
            android:layout_height="56dp"
            android:layout_marginBottom="20dp"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_carvia" />

        <!-- Thẻ kính chứa form đăng nhập -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng nhập"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/lg_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:text="Chào mừng bạn quay trở lại 👋"
                android:textSize="14sp"
                android:textColor="@color/lg_text_secondary" />

            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Email hoặc số điện thoại"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="16dp"
                android:textColor="@color/lg_text"
                android:textColorHint="@color/lg_text_secondary"
                android:background="@drawable/bg_glass_input"
                android:layout_marginBottom="14dp" />

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Mật khẩu"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:textColor="@color/lg_text"
                android:textColorHint="@color/lg_text_secondary"
                android:background="@drawable/bg_glass_input"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_forgot_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginBottom="18dp"
                android:padding="4dp"
                android:text="Quên mật khẩu?"
                android:textColor="@color/lg_accent_text"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_do_login"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="ĐĂNG NHẬP"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:backgroundTint="@color/lg_accent"
                app:cornerRadius="26dp"
                app:strokeColor="@color/lg_glass_stroke"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa có tài khoản? "
                android:textColor="@color/lg_text_secondary" />

            <TextView
                android:id="@+id/tv_go_to_register"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng ký ngay"
                android:textColor="@color/lg_accent_text"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
